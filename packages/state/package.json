{
  "name": "@blackboard/state",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format esm,cjs --dts --external @blackboard/types --external @blackboard/renderer",
    "dev": "tsup src/index.ts --format esm,cjs --dts --external @blackboard/types --external @blackboard/renderer --watch",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@blackboard/types": "workspace:*",
    "@blackboard/renderer": "workspace:*"
  }
}
