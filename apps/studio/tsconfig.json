{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "baseUrl": ".",
    "experimentalDecorators": true,
    "useDefineForClassFields": false,
    "types": ["node", "vite/client"],
    "allowJs": true,
    "jsx": "react-jsx",
    "paths": {
      "@/*": ["*"]
    },
    "allowImportingTsExtensions": true,
    "noEmit": true
  }
}
